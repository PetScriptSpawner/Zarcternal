-- Fly Logic
local flying = false
local flySpeed = 20
local bv, bg

-- Update Speed
local function updateSpeedLabel()
	SpeedLabel.Text = "Speed: "..flySpeed
end
plus.MouseButton1Click:Connect(function()
	flySpeed = flySpeed + 5
	updateSpeedLabel()
end)
minus.MouseButton1Click:Connect(function()
	flySpeed = math.max(5, flySpeed - 5)
	updateSpeedLabel()
end)

local input = {Up=false, Down=false}
UIS.InputBegan:Connect(function(key, gpe)
	if gpe then return end
	if key.KeyCode == Enum.KeyCode.Space then input.Up = true end
	if key.KeyCode == Enum.KeyCode.LeftShift then input.Down = true end
end)
UIS.InputEnded:Connect(function(key, gpe)
	if key.KeyCode == Enum.KeyCode.Space then input.Up = false end
	if key.KeyCode == Enum.KeyCode.LeftShift then input.Down = false end
end)

toggleButton.MouseButton1Click:Connect(function()
	flying = not flying
	if flying then
		bv = Instance.new("BodyVelocity", hrp)
		bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
		bv.Velocity = Vector3.new(0,0,0)

		bg = Instance.new("BodyGyro", hrp)
		bg.MaxTorque = Vector3.new(9e9,9e9,9e9)
		bg.P = 9e4
		bg.CFrame = hrp.CFrame

		hum.PlatformStand = true

		RunService.RenderStepped:Connect(function()
			if not flying then return end
			local move = hum.MoveDirection
			local vel = move * flySpeed

			if input.Up then
				vel = vel + Vector3.new(0, flySpeed, 0)
			end
			if input.Down then
				vel = vel + Vector3.new(0, -flySpeed, 0)
			end

			bv.Velocity = vel
			bg.CFrame = workspace.CurrentCamera.CFrame
		end)
	else
		if bv then bv:Destroy() end
		if bg then bg:Destroy() end
		hum.PlatformStand = false
	end
end)

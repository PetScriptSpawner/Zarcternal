-- GoTo button
local gotoButton = Instance.new("TextButton")
gotoButton.Size = UDim2.new(0.8,0,0.5,0)
gotoButton.Position = UDim2.new(0.1,0,0.25,0)
gotoButton.BackgroundColor3 = Color3.fromRGB(40,40,40)
